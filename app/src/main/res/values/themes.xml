<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PrathamChikitse" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/primary_variant</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/surface_warm</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="android:windowBackground">@color/background_warm</item>
    </style>

    <style name="Theme.PrathamChikitse" parent="Base.Theme.PrathamChikitse" />

    <!-- Modern Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Background color of the splash screen -->
        <item name="windowSplashScreenBackground">@color/background_warm</item>
        <!-- Icon to be displayed in the center -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- Theme to switch to after the splash screen -->
        <item name="postSplashScreenTheme">@style/Theme.PrathamChikitse</item>
    </style>
</resources>